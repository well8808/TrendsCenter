generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Market {
  BR
  US
}

enum DataOrigin {
  OFFICIAL
  OWNED
  MANUAL
  DEMO
}

enum SourceKind {
  CREATIVE_CENTER_TRENDS
  TOP_ADS
  KEYWORD_INSIGHTS
  CREATIVE_INSIGHTS
  AUDIENCE_INSIGHTS
  TIKTOK_ONE
  MARKET_SCOPE
  DISPLAY_API
  COMMERCIAL_MUSIC_LIBRARY
  OWNED_UPLOAD
  MANUAL_RESEARCH
  DEMO
}

enum SignalType {
  AUDIO
  FORMAT
  HASHTAG
  CREATOR
  REVIVAL
  US_TO_BR
}

enum SignalStatus {
  RISING
  RETURNING
  WATCH
  BLOCKED
  ARCHIVED
}

enum ConfidenceBand {
  LOW
  MEDIUM
  HIGH
}

enum SignalPriority {
  NOW
  NEXT
  WATCH
  HOLD
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum TrendStage {
  EMERGING
  ACCELERATING
  PROVING
  REVIVAL
  MONITOR
}

enum ComplianceSeverity {
  INFO
  WARNING
  BLOCKER
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ConnectorStatus {
  APPROVED
  PAUSED
  NEEDS_REVIEW
  BLOCKED
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum DecisionQueueStatus {
  ACTIVE
  SNOOZED
  DONE
  REMOVED
}

enum AuditEventType {
  SIGNAL_CREATED
  SIGNAL_UPDATED
  EVIDENCE_ATTACHED
  SOURCE_REGISTERED
  DECISION_QUEUED
  DECISION_REMOVED
  JOB_RECORDED
  COMPLIANCE_BLOCKED
  SYSTEM
}

enum AuthEmailKind {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  WORKSPACE_INVITE
}

enum AuthEmailStatus {
  QUEUED
  SENT
  FAILED
  SUPPRESSED
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AuthEventType {
  SIGNUP_CREATED
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  LOGIN_BLOCKED
  LOGOUT
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  EMAIL_VERIFICATION_FAILED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_RESET_FAILED
  WORKSPACE_INVITE_SENT
  WORKSPACE_INVITE_ACCEPTED
  WORKSPACE_INVITE_FAILED
  MEMBER_ROLE_CHANGED
  RATE_LIMITED
}

enum IngestRequestType {
  SIGNAL_CREATE
  EVIDENCE_APPEND
  SOURCE_REGISTER
  OFFICIAL_SNAPSHOT
}

enum IngestStatus {
  DRAFT
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
  SKIPPED
}

enum IngestStepName {
  RECEIVE
  VALIDATE
  NORMALIZE
  DEDUPE
  PERSIST
  SCORE
  AUDIT
}

enum ImportBatchKind {
  MANUAL_SIGNAL
  MANUAL_EVIDENCE
  OFFICIAL_SNAPSHOT
  CONNECTOR_BASELINE
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  name                    String?
  passwordHash            String
  status                  UserStatus               @default(PENDING_VERIFICATION)
  emailVerifiedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  memberships             WorkspaceMember[]
  sessions                AuthSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  sentInvites             WorkspaceInvite[]        @relation("WorkspaceInviteInviter")
  acceptedInvites         WorkspaceInvite[]        @relation("WorkspaceInviteAcceptedBy")
  authEvents              AuthEvent[]              @relation("AuthEventUser")
  actedAuthEvents         AuthEvent[]              @relation("AuthEventActor")
}

model Workspace {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  members            WorkspaceMember[]
  sessions           AuthSession[]
  connectors         Connector[]
  sources            Source[]
  sourceSnapshots    SourceSnapshot[]
  signals            Signal[]
  observations       SignalObservation[]
  scores             SignalScore[]
  evidence           Evidence[]
  decisionQueueItems DecisionQueueItem[]
  auditEvents        AuditEvent[]
  complianceFlags    ComplianceFlag[]
  mediaAssets        MediaAsset[]
  mediaDerivatives   MediaDerivative[]
  jobRuns            JobRun[]
  ingestRequests     IngestRequest[]
  importBatches      ImportBatch[]
  ingestionSteps     IngestionStep[]
  invites            WorkspaceInvite[]
  authEmailOutbox    AuthEmailOutbox[]
  authEvents         AuthEvent[]
}

model WorkspaceMember {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        WorkspaceRole    @default(MEMBER)
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId, role, status])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  sendCount  Int       @default(1)
  lastSentAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, consumedAt, expiresAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, consumedAt, expiresAt])
  @@index([expiresAt])
}

model WorkspaceInvite {
  id           String                @id @default(cuid())
  workspaceId  String
  workspace    Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email        String
  role         WorkspaceRole         @default(MEMBER)
  status       WorkspaceInviteStatus @default(PENDING)
  tokenHash    String                @unique
  invitedById  String
  invitedBy    User                  @relation("WorkspaceInviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedById String?
  acceptedBy   User?                 @relation("WorkspaceInviteAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([workspaceId, status, expiresAt])
  @@index([email, status, expiresAt])
}

model AuthEmailOutbox {
  id          String          @id @default(cuid())
  kind        AuthEmailKind
  status      AuthEmailStatus @default(QUEUED)
  toEmail     String
  subject     String
  body        String
  actionUrl   String?
  workspaceId String?
  workspace   Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?
  error       String?
  sentAt      DateTime?
  createdAt   DateTime        @default(now())

  @@index([kind, status, createdAt])
  @@index([toEmail, createdAt])
  @@index([workspaceId, createdAt])
}

model AuthRateLimit {
  id        String   @id @default(cuid())
  bucket    String
  key       String
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bucket, key])
  @@index([resetAt])
}

model AuthEvent {
  id          String        @id @default(cuid())
  type        AuthEventType
  success     Boolean       @default(true)
  emailHash   String?
  userId      String?
  user        User?         @relation("AuthEventUser", fields: [userId], references: [id], onDelete: SetNull)
  actorUserId String?
  actorUser   User?         @relation("AuthEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  workspaceId String?
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ipHash      String?
  reason      String?
  metadata    Json?
  createdAt   DateTime      @default(now())

  @@index([type, createdAt])
  @@index([emailHash, createdAt])
  @@index([workspaceId, type, createdAt])
  @@index([userId, createdAt])
}

model AuthSession {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userAgent   String?
  expiresAt   DateTime
  lastSeenAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([workspaceId, expiresAt])
}

model Connector {
  id                 String          @id @default(cuid())
  workspaceId        String
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug               String
  title              String
  kind               SourceKind
  origin             DataOrigin
  status             ConnectorStatus @default(NEEDS_REVIEW)
  market             Market?
  manualEntryEnabled Boolean         @default(true)
  officialSurface    String?
  policyNotes        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  sources            Source[]
  ingestRequests     IngestRequest[]
  importBatches      ImportBatch[]

  @@unique([workspaceId, slug])
  @@index([origin, kind, status])
  @@index([workspaceId, origin, kind, status])
}

model Source {
  id             String           @id @default(cuid())
  workspaceId    String
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title          String
  kind           SourceKind
  origin         DataOrigin
  url            String?
  market         Market
  confidence     ConfidenceBand   @default(LOW)
  notes          String?
  coverage       String?
  freshness      String?
  gap            String?
  dedupeKey      String?
  connectorId    String?
  connector      Connector?       @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  snapshots      SourceSnapshot[]
  evidence       Evidence[]
  signals        Signal[]
  ingestRequests IngestRequest[]
  importBatches  ImportBatch[]
  auditEvents    AuditEvent[]

  @@unique([workspaceId, dedupeKey])
  @@index([origin, kind, market])
  @@index([workspaceId, origin, kind, market])
}

model SourceSnapshot {
  id             String              @id @default(cuid())
  workspaceId    String
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId       String
  source         Source              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  importBatchId  String?
  importBatch    ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId       String?
  jobRun         JobRun?             @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  collectedAt    DateTime
  rawPayloadHash String
  storagePath    String?
  recordCount    Int                 @default(0)
  isDemo         Boolean             @default(false)
  createdAt      DateTime            @default(now())
  observations   SignalObservation[]
  evidence       Evidence[]

  @@index([workspaceId, collectedAt])
}

model Signal {
  id                 String              @id @default(cuid())
  workspaceId        String
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title              String
  summary            String
  type               SignalType
  market             Market
  audience           String
  status             SignalStatus        @default(WATCH)
  priority           SignalPriority      @default(WATCH)
  riskLevel          RiskLevel           @default(LOW)
  stage              TrendStage          @default(MONITOR)
  strength           Int                 @default(0)
  trendWindow        String?
  decision           String?
  nextAction         String?
  tags               Json?
  scoreDrivers       Json?
  dedupeKey          String?
  importBatchId      String?
  importBatch        ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  lastIngestedAt     DateTime?
  processedAt        DateTime?
  origin             DataOrigin
  sourceId           String
  source             Source              @relation(fields: [sourceId], references: [id])
  confidence         ConfidenceBand      @default(LOW)
  evidenceCount      Int                 @default(0)
  isDemo             Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  observations       SignalObservation[]
  scores             SignalScore[]
  evidence           Evidence[]
  compliance         ComplianceFlag[]
  decisionQueueItems DecisionQueueItem[]
  auditEvents        AuditEvent[]
  ingestRequests     IngestRequest[]

  @@unique([workspaceId, dedupeKey])
  @@index([market, type, status])
  @@index([priority, riskLevel, stage])
  @@index([origin, isDemo])
  @@index([workspaceId, market, type, status])
  @@index([workspaceId, priority, riskLevel, stage])
}

model SignalObservation {
  id           String          @id @default(cuid())
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId     String
  signal       Signal          @relation(fields: [signalId], references: [id], onDelete: Cascade)
  snapshotId   String?
  snapshot     SourceSnapshot? @relation(fields: [snapshotId], references: [id])
  observedAt   DateTime
  rank         Int?
  postCount    Int?
  viewCount    BigInt?
  likeCount    BigInt?
  commentCount BigInt?
  shareCount   BigInt?
  rawMetrics   Json?
  createdAt    DateTime        @default(now())

  @@index([signalId, observedAt])
  @@index([workspaceId, observedAt])
}

model SignalScore {
  id                    String         @id @default(cuid())
  workspaceId           String
  workspace             Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId              String
  signal                Signal         @relation(fields: [signalId], references: [id], onDelete: Cascade)
  calculatedAt          DateTime       @default(now())
  score                 Int
  confidence            ConfidenceBand
  velocity7d            Int
  acceleration          Int
  brazilFit             Int
  usTransferability     Int
  formatRepeatability   Int
  creatorSignal         Int
  audioCommercialUsable Int
  revivalStrength       Int
  evidenceQuality       Int
  riskPenalty           Int
  modelVersion          String         @default("score-v0.1")
  explanation           String?

  @@index([signalId, calculatedAt])
  @@index([workspaceId, calculatedAt])
}

model Evidence {
  id            String          @id @default(cuid())
  workspaceId   String
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId      String?
  signal        Signal?         @relation(fields: [signalId], references: [id], onDelete: SetNull)
  sourceId      String
  source        Source          @relation(fields: [sourceId], references: [id])
  importBatchId String?
  importBatch   ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId      String?
  jobRun        JobRun?         @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  snapshotId    String?
  snapshot      SourceSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  dedupeKey     String?
  title         String
  url           String?
  excerpt       String?
  note          String?
  quality       ConfidenceBand  @default(LOW)
  capturedAt    DateTime
  isDemo        Boolean         @default(false)
  createdAt     DateTime        @default(now())

  @@unique([workspaceId, dedupeKey])
  @@index([sourceId, capturedAt])
  @@index([signalId, capturedAt])
  @@index([workspaceId, capturedAt])
}

model DecisionQueueItem {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId    String
  signal      Signal              @relation(fields: [signalId], references: [id], onDelete: Cascade)
  status      DecisionQueueStatus @default(ACTIVE)
  label       String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([workspaceId, signalId])
  @@index([status, createdAt])
  @@index([workspaceId, status, createdAt])
}

model AuditEvent {
  id            String         @id @default(cuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type          AuditEventType
  signalId      String?
  signal        Signal?        @relation(fields: [signalId], references: [id], onDelete: SetNull)
  sourceId      String?
  source        Source?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  importBatchId String?
  importBatch   ImportBatch?   @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId      String?
  jobRun        JobRun?        @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  label         String
  value         String
  tone          String         @default("violet")
  message       String?
  actor         String         @default("system")
  metadata      Json?
  eventAt       DateTime       @default(now())
  createdAt     DateTime       @default(now())

  @@index([signalId, eventAt])
  @@index([type, eventAt])
  @@index([workspaceId, type, eventAt])
}

model ComplianceFlag {
  id          String             @id @default(cuid())
  workspaceId String
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId    String?
  signal      Signal?            @relation(fields: [signalId], references: [id], onDelete: SetNull)
  severity    ComplianceSeverity
  code        String
  message     String
  policyRef   String?
  resolvedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([severity, resolvedAt])
  @@index([workspaceId, severity, resolvedAt])
}

model MediaAsset {
  id             String            @id @default(cuid())
  workspaceId    String
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerLabel     String
  origin         DataOrigin
  storagePath    String
  mimeType       String
  fileHash       String
  isLicensed     Boolean           @default(false)
  metadataReport Json?
  createdAt      DateTime          @default(now())
  derivatives    MediaDerivative[]

  @@index([workspaceId, origin, createdAt])
}

model MediaDerivative {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mediaId     String
  media       MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  purpose     String
  storagePath String
  fileHash    String
  createdAt   DateTime   @default(now())

  @@index([workspaceId, createdAt])
}

model JobRun {
  id            String           @id @default(cuid())
  workspaceId   String
  workspace     Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  status        JobStatus        @default(QUEUED)
  stage         IngestStepName?
  requestId     String?
  request       IngestRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  importBatchId String?
  importBatch   ImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  payload       Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  error         String?
  createdAt     DateTime         @default(now())
  snapshots     SourceSnapshot[]
  evidence      Evidence[]
  auditEvents   AuditEvent[]

  @@index([name, status, createdAt])
  @@index([importBatchId, status])
  @@index([workspaceId, status, createdAt])
}

model IngestRequest {
  id            String            @id @default(cuid())
  workspaceId   String
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestKey    String
  type          IngestRequestType
  status        IngestStatus      @default(QUEUED)
  market        Market
  origin        DataOrigin
  connectorId   String?
  connector     Connector?        @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  sourceId      String?
  source        Source?           @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  signalId      String?
  signal        Signal?           @relation(fields: [signalId], references: [id], onDelete: SetNull)
  title         String
  submittedBy   String            @default("operator")
  submittedAt   DateTime          @default(now())
  collectedAt   DateTime?
  processedAt   DateTime?
  completedAt   DateTime?
  error         String?
  payload       Json?
  isDemo        Boolean           @default(false)
  importBatches ImportBatch[]
  jobRuns       JobRun[]

  @@unique([workspaceId, requestKey])
  @@index([status, submittedAt])
  @@index([market, origin, type])
  @@index([workspaceId, status, submittedAt])
}

model ImportBatch {
  id             String           @id @default(cuid())
  workspaceId    String
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  idempotencyKey String
  kind           ImportBatchKind
  status         IngestStatus     @default(QUEUED)
  market         Market
  origin         DataOrigin
  connectorId    String?
  connector      Connector?       @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  requestId      String?
  request        IngestRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  sourceId       String?
  source         Source?          @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title          String
  itemCount      Int              @default(0)
  payloadHash    String?
  payload        Json?
  collectedAt    DateTime?
  processedAt    DateTime?
  completedAt    DateTime?
  error          String?
  isDemo         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  steps          IngestionStep[]
  jobRuns        JobRun[]
  snapshots      SourceSnapshot[]
  signals        Signal[]
  evidence       Evidence[]
  auditEvents    AuditEvent[]

  @@unique([workspaceId, idempotencyKey])
  @@index([status, createdAt])
  @@index([market, origin, kind])
  @@index([workspaceId, status, createdAt])
}

model IngestionStep {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  batchId     String
  batch       ImportBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  name        IngestStepName
  status      IngestStatus   @default(QUEUED)
  sequence    Int
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  notes       String?
  createdAt   DateTime       @default(now())

  @@index([batchId, sequence])
  @@index([name, status])
  @@index([workspaceId, name, status])
}

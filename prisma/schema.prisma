generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Market {
  BR
  US
}

enum DataOrigin {
  OFFICIAL
  OWNED
  MANUAL
  DEMO
}

enum SourceKind {
  CREATIVE_CENTER_TRENDS
  TOP_ADS
  KEYWORD_INSIGHTS
  CREATIVE_INSIGHTS
  AUDIENCE_INSIGHTS
  TIKTOK_ONE
  MARKET_SCOPE
  DISPLAY_API
  COMMERCIAL_MUSIC_LIBRARY
  OWNED_UPLOAD
  MANUAL_RESEARCH
  DEMO
}

enum SignalType {
  AUDIO
  FORMAT
  HASHTAG
  CREATOR
  REVIVAL
  US_TO_BR
}

enum SignalStatus {
  RISING
  RETURNING
  WATCH
  BLOCKED
  ARCHIVED
}

enum ConfidenceBand {
  LOW
  MEDIUM
  HIGH
}

enum SignalPriority {
  NOW
  NEXT
  WATCH
  HOLD
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum TrendStage {
  EMERGING
  ACCELERATING
  PROVING
  REVIVAL
  MONITOR
}

enum ComplianceSeverity {
  INFO
  WARNING
  BLOCKER
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

model Source {
  id          String           @id @default(cuid())
  title       String
  kind        SourceKind
  origin      DataOrigin
  url         String?
  market      Market
  confidence  ConfidenceBand  @default(LOW)
  notes       String?
  coverage    String?
  freshness   String?
  gap         String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  snapshots   SourceSnapshot[]
  evidence    EvidenceItem[]
  signals     TrendSignal[]
}

model SourceSnapshot {
  id              String             @id @default(cuid())
  sourceId        String
  source          Source             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  collectedAt     DateTime
  rawPayloadHash  String
  storagePath     String?
  recordCount     Int                @default(0)
  isDemo          Boolean            @default(false)
  createdAt       DateTime           @default(now())
  observations    TrendObservation[]
}

model TrendSignal {
  id             String             @id @default(cuid())
  title          String
  summary        String
  type           SignalType
  market         Market
  audience       String
  status         SignalStatus       @default(WATCH)
  priority       SignalPriority     @default(WATCH)
  riskLevel      RiskLevel          @default(LOW)
  stage          TrendStage         @default(MONITOR)
  strength       Int                @default(0)
  trendWindow    String?
  decision       String?
  nextAction     String?
  tags           Json?
  scoreDrivers   Json?
  origin         DataOrigin
  sourceId       String
  source         Source             @relation(fields: [sourceId], references: [id])
  confidence     ConfidenceBand     @default(LOW)
  evidenceCount  Int                @default(0)
  isDemo         Boolean            @default(false)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  observations   TrendObservation[]
  scores         TrendScore[]
  evidence       EvidenceItem[]
  compliance     ComplianceFlag[]
  savedBy        WorkspaceSavedSignal[]
  history        SignalHistoryEvent[]

  @@index([market, type, status])
  @@index([priority, riskLevel, stage])
  @@index([origin, isDemo])
}

model TrendObservation {
  id            String         @id @default(cuid())
  signalId      String
  signal        TrendSignal    @relation(fields: [signalId], references: [id], onDelete: Cascade)
  snapshotId    String?
  snapshot      SourceSnapshot? @relation(fields: [snapshotId], references: [id])
  observedAt    DateTime
  rank          Int?
  postCount     Int?
  viewCount     BigInt?
  likeCount     BigInt?
  commentCount  BigInt?
  shareCount    BigInt?
  rawMetrics    Json?
  createdAt     DateTime       @default(now())

  @@index([signalId, observedAt])
}

model TrendScore {
  id                    String          @id @default(cuid())
  signalId              String
  signal                TrendSignal     @relation(fields: [signalId], references: [id], onDelete: Cascade)
  calculatedAt          DateTime        @default(now())
  score                 Int
  confidence            ConfidenceBand
  velocity7d            Int
  acceleration          Int
  brazilFit             Int
  usTransferability     Int
  formatRepeatability   Int
  creatorSignal         Int
  audioCommercialUsable Int
  revivalStrength       Int
  evidenceQuality       Int
  riskPenalty           Int
  modelVersion          String          @default("score-v0.1")
  explanation           String?

  @@index([signalId, calculatedAt])
}

model EvidenceItem {
  id          String       @id @default(cuid())
  signalId    String?
  signal      TrendSignal? @relation(fields: [signalId], references: [id], onDelete: SetNull)
  sourceId    String
  source      Source       @relation(fields: [sourceId], references: [id])
  title       String
  url         String?
  excerpt     String?
  note        String?
  quality     ConfidenceBand @default(LOW)
  capturedAt  DateTime
  isDemo      Boolean      @default(false)
  createdAt   DateTime     @default(now())

  @@index([sourceId, capturedAt])
}

model WorkspaceSavedSignal {
  id        String      @id @default(cuid())
  signalId  String      @unique
  signal    TrendSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  label     String?
  notes     String?
  createdAt DateTime    @default(now())

  @@index([signalId, createdAt])
}

model SignalHistoryEvent {
  id        String      @id @default(cuid())
  signalId  String
  signal    TrendSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  label     String
  value     String
  tone      String
  eventAt   DateTime    @default(now())
  createdAt DateTime    @default(now())

  @@index([signalId, eventAt])
}

model ComplianceFlag {
  id          String             @id @default(cuid())
  signalId    String?
  signal      TrendSignal?       @relation(fields: [signalId], references: [id], onDelete: SetNull)
  severity    ComplianceSeverity
  code        String
  message     String
  policyRef   String?
  resolvedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([severity, resolvedAt])
}

model MediaAsset {
  id             String           @id @default(cuid())
  ownerLabel     String
  origin         DataOrigin
  storagePath    String
  mimeType       String
  fileHash       String
  isLicensed     Boolean          @default(false)
  metadataReport Json?
  createdAt      DateTime         @default(now())
  derivatives    MediaDerivative[]
}

model MediaDerivative {
  id          String     @id @default(cuid())
  mediaId     String
  media       MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  purpose     String
  storagePath String
  fileHash    String
  createdAt   DateTime   @default(now())
}

model JobRun {
  id          String    @id @default(cuid())
  name        String
  status      JobStatus @default(QUEUED)
  payload     Json?
  startedAt   DateTime?
  finishedAt  DateTime?
  error       String?
  createdAt   DateTime  @default(now())

  @@index([name, status, createdAt])
}

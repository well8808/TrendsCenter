generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Market {
  BR
  US
}

enum DataOrigin {
  OFFICIAL
  OWNED
  MANUAL
  DEMO
}

enum SourceKind {
  CREATIVE_CENTER_TRENDS
  TOP_ADS
  KEYWORD_INSIGHTS
  CREATIVE_INSIGHTS
  AUDIENCE_INSIGHTS
  TIKTOK_ONE
  MARKET_SCOPE
  DISPLAY_API
  COMMERCIAL_MUSIC_LIBRARY
  OWNED_UPLOAD
  MANUAL_RESEARCH
  DEMO
}

enum SignalType {
  AUDIO
  FORMAT
  HASHTAG
  CREATOR
  REVIVAL
  US_TO_BR
}

enum SignalStatus {
  RISING
  RETURNING
  WATCH
  BLOCKED
  ARCHIVED
}

enum ConfidenceBand {
  LOW
  MEDIUM
  HIGH
}

enum SignalPriority {
  NOW
  NEXT
  WATCH
  HOLD
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum TrendStage {
  EMERGING
  ACCELERATING
  PROVING
  REVIVAL
  MONITOR
}

enum ComplianceSeverity {
  INFO
  WARNING
  BLOCKER
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum ConnectorStatus {
  APPROVED
  PAUSED
  NEEDS_REVIEW
  BLOCKED
}

enum IngestRequestType {
  SIGNAL_CREATE
  EVIDENCE_APPEND
  SOURCE_REGISTER
  OFFICIAL_SNAPSHOT
}

enum IngestStatus {
  DRAFT
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
  SKIPPED
}

enum IngestStepName {
  RECEIVE
  VALIDATE
  NORMALIZE
  DEDUPE
  PERSIST
  SCORE
  AUDIT
}

enum ImportBatchKind {
  MANUAL_SIGNAL
  MANUAL_EVIDENCE
  OFFICIAL_SNAPSHOT
  DEMO_SEED
}

model SourceConnector {
  id                 String          @id @default(cuid())
  slug               String          @unique
  title              String
  kind               SourceKind
  origin             DataOrigin
  status             ConnectorStatus @default(NEEDS_REVIEW)
  market             Market?
  manualEntryEnabled Boolean         @default(true)
  officialSurface    String?
  policyNotes        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  sources            Source[]
  ingestRequests     IngestRequest[]
  importBatches      ImportBatch[]

  @@index([origin, kind, status])
}

model Source {
  id             String           @id @default(cuid())
  title          String
  kind           SourceKind
  origin         DataOrigin
  url            String?
  market         Market
  confidence     ConfidenceBand   @default(LOW)
  notes          String?
  coverage       String?
  freshness      String?
  gap            String?
  dedupeKey      String?          @unique
  connectorId    String?
  connector      SourceConnector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  snapshots      SourceSnapshot[]
  evidence       EvidenceItem[]
  signals        TrendSignal[]
  ingestRequests IngestRequest[]
  importBatches  ImportBatch[]

  @@index([origin, kind, market])
}

model SourceSnapshot {
  id             String             @id @default(cuid())
  sourceId       String
  source         Source             @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  importBatchId  String?
  importBatch    ImportBatch?       @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId       String?
  jobRun         JobRun?            @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  collectedAt    DateTime
  rawPayloadHash String
  storagePath    String?
  recordCount    Int                @default(0)
  isDemo         Boolean            @default(false)
  createdAt      DateTime           @default(now())
  observations   TrendObservation[]
  evidence       EvidenceItem[]
}

model TrendSignal {
  id             String                 @id @default(cuid())
  title          String
  summary        String
  type           SignalType
  market         Market
  audience       String
  status         SignalStatus           @default(WATCH)
  priority       SignalPriority         @default(WATCH)
  riskLevel      RiskLevel              @default(LOW)
  stage          TrendStage             @default(MONITOR)
  strength       Int                    @default(0)
  trendWindow    String?
  decision       String?
  nextAction     String?
  tags           Json?
  scoreDrivers   Json?
  dedupeKey      String?                @unique
  importBatchId  String?
  importBatch    ImportBatch?           @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  lastIngestedAt DateTime?
  processedAt    DateTime?
  origin         DataOrigin
  sourceId       String
  source         Source                 @relation(fields: [sourceId], references: [id])
  confidence     ConfidenceBand         @default(LOW)
  evidenceCount  Int                    @default(0)
  isDemo         Boolean                @default(false)
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt
  observations   TrendObservation[]
  scores         TrendScore[]
  evidence       EvidenceItem[]
  compliance     ComplianceFlag[]
  savedBy        WorkspaceSavedSignal[]
  history        SignalHistoryEvent[]
  ingestRequests IngestRequest[]

  @@index([market, type, status])
  @@index([priority, riskLevel, stage])
  @@index([origin, isDemo])
}

model TrendObservation {
  id           String          @id @default(cuid())
  signalId     String
  signal       TrendSignal     @relation(fields: [signalId], references: [id], onDelete: Cascade)
  snapshotId   String?
  snapshot     SourceSnapshot? @relation(fields: [snapshotId], references: [id])
  observedAt   DateTime
  rank         Int?
  postCount    Int?
  viewCount    BigInt?
  likeCount    BigInt?
  commentCount BigInt?
  shareCount   BigInt?
  rawMetrics   Json?
  createdAt    DateTime        @default(now())

  @@index([signalId, observedAt])
}

model TrendScore {
  id                    String         @id @default(cuid())
  signalId              String
  signal                TrendSignal    @relation(fields: [signalId], references: [id], onDelete: Cascade)
  calculatedAt          DateTime       @default(now())
  score                 Int
  confidence            ConfidenceBand
  velocity7d            Int
  acceleration          Int
  brazilFit             Int
  usTransferability     Int
  formatRepeatability   Int
  creatorSignal         Int
  audioCommercialUsable Int
  revivalStrength       Int
  evidenceQuality       Int
  riskPenalty           Int
  modelVersion          String         @default("score-v0.1")
  explanation           String?

  @@index([signalId, calculatedAt])
}

model EvidenceItem {
  id            String          @id @default(cuid())
  signalId      String?
  signal        TrendSignal?    @relation(fields: [signalId], references: [id], onDelete: SetNull)
  sourceId      String
  source        Source          @relation(fields: [sourceId], references: [id])
  importBatchId String?
  importBatch   ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId      String?
  jobRun        JobRun?         @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  snapshotId    String?
  snapshot      SourceSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  dedupeKey     String?         @unique
  title         String
  url           String?
  excerpt       String?
  note          String?
  quality       ConfidenceBand  @default(LOW)
  capturedAt    DateTime
  isDemo        Boolean         @default(false)
  createdAt     DateTime        @default(now())

  @@index([sourceId, capturedAt])
  @@index([signalId, capturedAt])
}

model WorkspaceSavedSignal {
  id        String      @id @default(cuid())
  signalId  String      @unique
  signal    TrendSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  label     String?
  notes     String?
  createdAt DateTime    @default(now())

  @@index([signalId, createdAt])
}

model SignalHistoryEvent {
  id        String      @id @default(cuid())
  signalId  String
  signal    TrendSignal @relation(fields: [signalId], references: [id], onDelete: Cascade)
  label     String
  value     String
  tone      String
  eventAt   DateTime    @default(now())
  createdAt DateTime    @default(now())

  @@index([signalId, eventAt])
}

model ComplianceFlag {
  id         String             @id @default(cuid())
  signalId   String?
  signal     TrendSignal?       @relation(fields: [signalId], references: [id], onDelete: SetNull)
  severity   ComplianceSeverity
  code       String
  message    String
  policyRef  String?
  resolvedAt DateTime?
  createdAt  DateTime           @default(now())

  @@index([severity, resolvedAt])
}

model MediaAsset {
  id             String            @id @default(cuid())
  ownerLabel     String
  origin         DataOrigin
  storagePath    String
  mimeType       String
  fileHash       String
  isLicensed     Boolean           @default(false)
  metadataReport Json?
  createdAt      DateTime          @default(now())
  derivatives    MediaDerivative[]
}

model MediaDerivative {
  id          String     @id @default(cuid())
  mediaId     String
  media       MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  purpose     String
  storagePath String
  fileHash    String
  createdAt   DateTime   @default(now())
}

model JobRun {
  id            String           @id @default(cuid())
  name          String
  status        JobStatus        @default(QUEUED)
  stage         IngestStepName?
  requestId     String?
  request       IngestRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  importBatchId String?
  importBatch   ImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  payload       Json?
  startedAt     DateTime?
  finishedAt    DateTime?
  error         String?
  createdAt     DateTime         @default(now())
  snapshots     SourceSnapshot[]
  evidence      EvidenceItem[]

  @@index([name, status, createdAt])
  @@index([importBatchId, status])
}

model IngestRequest {
  id            String            @id @default(cuid())
  requestKey    String            @unique
  type          IngestRequestType
  status        IngestStatus      @default(QUEUED)
  market        Market
  origin        DataOrigin
  connectorId   String?
  connector     SourceConnector?  @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  sourceId      String?
  source        Source?           @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  signalId      String?
  signal        TrendSignal?      @relation(fields: [signalId], references: [id], onDelete: SetNull)
  title         String
  submittedBy   String            @default("operator")
  submittedAt   DateTime          @default(now())
  collectedAt   DateTime?
  processedAt   DateTime?
  completedAt   DateTime?
  error         String?
  payload       Json?
  isDemo        Boolean           @default(false)
  importBatches ImportBatch[]
  jobRuns       JobRun[]

  @@index([status, submittedAt])
  @@index([market, origin, type])
}

model ImportBatch {
  id             String           @id @default(cuid())
  idempotencyKey String           @unique
  kind           ImportBatchKind
  status         IngestStatus     @default(QUEUED)
  market         Market
  origin         DataOrigin
  connectorId    String?
  connector      SourceConnector? @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  requestId      String?
  request        IngestRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  sourceId       String?
  source         Source?          @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title          String
  itemCount      Int              @default(0)
  payloadHash    String?
  payload        Json?
  collectedAt    DateTime?
  processedAt    DateTime?
  completedAt    DateTime?
  error          String?
  isDemo         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  steps          IngestionStep[]
  jobRuns        JobRun[]
  snapshots      SourceSnapshot[]
  signals        TrendSignal[]
  evidence       EvidenceItem[]

  @@index([status, createdAt])
  @@index([market, origin, kind])
}

model IngestionStep {
  id          String         @id @default(cuid())
  batchId     String
  batch       ImportBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  name        IngestStepName
  status      IngestStatus   @default(QUEUED)
  sequence    Int
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  notes       String?
  createdAt   DateTime       @default(now())

  @@index([batchId, sequence])
  @@index([name, status])
}

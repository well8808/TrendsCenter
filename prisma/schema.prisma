generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Market {
  BR
  US
}

enum DataOrigin {
  OFFICIAL
  OWNED
  MANUAL
  DEMO
}

enum SourceKind {
  CREATIVE_CENTER_TRENDS
  TOP_ADS
  KEYWORD_INSIGHTS
  CREATIVE_INSIGHTS
  AUDIENCE_INSIGHTS
  TIKTOK_ONE
  MARKET_SCOPE
  DISPLAY_API
  COMMERCIAL_MUSIC_LIBRARY
  OWNED_UPLOAD
  MANUAL_RESEARCH
  DEMO
}

enum SignalType {
  AUDIO
  FORMAT
  HASHTAG
  CREATOR
  REVIVAL
  US_TO_BR
}

enum SignalStatus {
  RISING
  RETURNING
  WATCH
  BLOCKED
  ARCHIVED
}

enum ConfidenceBand {
  LOW
  MEDIUM
  HIGH
}

enum SignalPriority {
  NOW
  NEXT
  WATCH
  HOLD
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum TrendStage {
  EMERGING
  ACCELERATING
  PROVING
  REVIVAL
  MONITOR
}

enum ComplianceSeverity {
  INFO
  WARNING
  BLOCKER
}

enum JobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  DEAD_LETTERED
  CANCELED
}

enum ConnectorStatus {
  APPROVED
  PAUSED
  NEEDS_REVIEW
  BLOCKED
}

enum UserStatus {
  PENDING_VERIFICATION
  ACTIVE
  DISABLED
}

enum WorkspaceRole {
  OWNER
  ADMIN
  MEMBER
}

enum MembershipStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum DecisionQueueStatus {
  ACTIVE
  SNOOZED
  DONE
  REMOVED
}

enum AuditEventType {
  SIGNAL_CREATED
  SIGNAL_UPDATED
  EVIDENCE_ATTACHED
  SOURCE_REGISTERED
  DECISION_QUEUED
  DECISION_REMOVED
  JOB_RECORDED
  COMPLIANCE_BLOCKED
  SYSTEM
}

enum AuthEmailKind {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  WORKSPACE_INVITE
}

enum AuthEmailStatus {
  QUEUED
  PROCESSING
  SENT
  FAILED
  SUPPRESSED
}

enum WorkspaceInviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AuthEventType {
  SIGNUP_CREATED
  LOGIN_SUCCEEDED
  LOGIN_FAILED
  LOGIN_BLOCKED
  LOGOUT
  EMAIL_VERIFICATION_SENT
  EMAIL_VERIFIED
  EMAIL_VERIFICATION_FAILED
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
  PASSWORD_RESET_FAILED
  WORKSPACE_INVITE_SENT
  WORKSPACE_INVITE_ACCEPTED
  WORKSPACE_INVITE_FAILED
  MEMBER_ROLE_CHANGED
  RATE_LIMITED
}

enum IngestRequestType {
  SIGNAL_CREATE
  EVIDENCE_APPEND
  SOURCE_REGISTER
  OFFICIAL_SNAPSHOT
}

enum IngestStatus {
  DRAFT
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
  SKIPPED
}

enum IngestStepName {
  RECEIVE
  VALIDATE
  NORMALIZE
  DEDUPE
  PERSIST
  SCORE
  AUDIT
}

enum ImportBatchKind {
  MANUAL_SIGNAL
  MANUAL_EVIDENCE
  OFFICIAL_SNAPSHOT
  CONNECTOR_BASELINE
}

enum TrendEntityType {
  VIDEO
  CREATOR
  SOUND
  HASHTAG
}

model User {
  id                      String                   @id @default(cuid())
  email                   String                   @unique
  name                    String?
  passwordHash            String
  status                  UserStatus               @default(PENDING_VERIFICATION)
  emailVerifiedAt         DateTime?
  createdAt               DateTime                 @default(now())
  updatedAt               DateTime                 @updatedAt
  memberships             WorkspaceMember[]
  sessions                AuthSession[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  sentInvites             WorkspaceInvite[]        @relation("WorkspaceInviteInviter")
  acceptedInvites         WorkspaceInvite[]        @relation("WorkspaceInviteAcceptedBy")
  authEvents              AuthEvent[]              @relation("AuthEventUser")
  actedAuthEvents         AuthEvent[]              @relation("AuthEventActor")
  searchQueryLogs         SearchQueryLog[]
}

model Workspace {
  id                 String              @id @default(cuid())
  slug               String              @unique
  name               String
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  members            WorkspaceMember[]
  sessions           AuthSession[]
  connectors         Connector[]
  sources            Source[]
  sourceSnapshots    SourceSnapshot[]
  signals            Signal[]
  observations       SignalObservation[]
  scores             SignalScore[]
  evidence           Evidence[]
  decisionQueueItems DecisionQueueItem[]
  auditEvents        AuditEvent[]
  complianceFlags    ComplianceFlag[]
  mediaAssets        MediaAsset[]
  mediaDerivatives   MediaDerivative[]
  jobRuns            JobRun[]
  ingestRequests     IngestRequest[]
  importBatches      ImportBatch[]
  ingestionSteps     IngestionStep[]
  invites            WorkspaceInvite[]
  authEmailOutbox    AuthEmailOutbox[]
  authEvents         AuthEvent[]
  creators           Creator[]
  sounds             Sound[]
  hashtags           Hashtag[]
  videos             Video[]
  trendSnapshots     TrendSnapshot[]
  trendEvidence      TrendEvidence[]
  searchQueryLogs    SearchQueryLog[]
}

model WorkspaceMember {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        WorkspaceRole    @default(MEMBER)
  status      MembershipStatus @default(ACTIVE)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([userId, workspaceId])
  @@index([workspaceId, role, status])
}

model EmailVerificationToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  sendCount  Int       @default(1)
  lastSentAt DateTime  @default(now())
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, consumedAt, expiresAt])
  @@index([expiresAt])
}

model PasswordResetToken {
  id         String    @id @default(cuid())
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String    @unique
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([userId, consumedAt, expiresAt])
  @@index([expiresAt])
}

model WorkspaceInvite {
  id           String                @id @default(cuid())
  workspaceId  String
  workspace    Workspace             @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  email        String
  role         WorkspaceRole         @default(MEMBER)
  status       WorkspaceInviteStatus @default(PENDING)
  tokenHash    String                @unique
  invitedById  String
  invitedBy    User                  @relation("WorkspaceInviteInviter", fields: [invitedById], references: [id], onDelete: Cascade)
  acceptedById String?
  acceptedBy   User?                 @relation("WorkspaceInviteAcceptedBy", fields: [acceptedById], references: [id], onDelete: SetNull)
  expiresAt    DateTime
  acceptedAt   DateTime?
  revokedAt    DateTime?
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  @@index([workspaceId, status, expiresAt])
  @@index([email, status, expiresAt])
}

model AuthEmailOutbox {
  id                String          @id @default(cuid())
  kind              AuthEmailKind
  status            AuthEmailStatus @default(QUEUED)
  toEmail           String
  subject           String
  body              String
  actionUrl         String?
  workspaceId       String?
  workspace         Workspace?      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId            String?
  provider          String?
  providerMessageId String?
  dedupeKey         String?
  attemptCount      Int             @default(0)
  maxAttempts       Int             @default(5)
  nextAttemptAt     DateTime        @default(now())
  leaseExpiresAt    DateTime?
  claimToken        String?
  error             String?
  lastError         String?
  sentAt            DateTime?
  processedAt       DateTime?
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  @@unique([workspaceId, dedupeKey])
  @@index([kind, status, nextAttemptAt])
  @@index([toEmail, createdAt])
  @@index([workspaceId, status, nextAttemptAt])
}

model AuthRateLimit {
  id        String   @id @default(cuid())
  bucket    String
  key       String
  count     Int      @default(0)
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([bucket, key])
  @@index([resetAt])
}

model AuthEvent {
  id          String        @id @default(cuid())
  type        AuthEventType
  success     Boolean       @default(true)
  emailHash   String?
  userId      String?
  user        User?         @relation("AuthEventUser", fields: [userId], references: [id], onDelete: SetNull)
  actorUserId String?
  actorUser   User?         @relation("AuthEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)
  workspaceId String?
  workspace   Workspace?    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ipHash      String?
  reason      String?
  metadata    Json?
  createdAt   DateTime      @default(now())

  @@index([type, createdAt])
  @@index([emailHash, createdAt])
  @@index([workspaceId, type, createdAt])
  @@index([userId, createdAt])
}

model AuthSession {
  id          String    @id @default(cuid())
  tokenHash   String    @unique
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userAgent   String?
  expiresAt   DateTime
  lastSeenAt  DateTime  @default(now())
  createdAt   DateTime  @default(now())

  @@index([userId, expiresAt])
  @@index([workspaceId, expiresAt])
}

model Connector {
  id                 String          @id @default(cuid())
  workspaceId        String
  workspace          Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  slug               String
  title              String
  kind               SourceKind
  origin             DataOrigin
  status             ConnectorStatus @default(NEEDS_REVIEW)
  market             Market?
  manualEntryEnabled Boolean         @default(true)
  officialSurface    String?
  policyNotes        String?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt
  sources            Source[]
  ingestRequests     IngestRequest[]
  importBatches      ImportBatch[]

  @@unique([workspaceId, slug])
  @@index([origin, kind, status])
  @@index([workspaceId, origin, kind, status])
}

model Source {
  id             String           @id @default(cuid())
  workspaceId    String
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title          String
  kind           SourceKind
  origin         DataOrigin
  url            String?
  market         Market
  confidence     ConfidenceBand   @default(LOW)
  notes          String?
  coverage       String?
  freshness      String?
  gap            String?
  dedupeKey      String?
  connectorId    String?
  connector      Connector?       @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  snapshots      SourceSnapshot[]
  evidence       Evidence[]
  signals        Signal[]
  ingestRequests IngestRequest[]
  importBatches  ImportBatch[]
  auditEvents    AuditEvent[]
  creators       Creator[]
  sounds         Sound[]
  hashtags       Hashtag[]
  videos         Video[]
  trendSnapshots TrendSnapshot[]
  trendEvidence  TrendEvidence[]

  @@unique([workspaceId, dedupeKey])
  @@index([origin, kind, market])
  @@index([workspaceId, origin, kind, market])
}

model SourceSnapshot {
  id             String              @id @default(cuid())
  workspaceId    String
  workspace      Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId       String
  source         Source              @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  importBatchId  String?
  importBatch    ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId       String?
  jobRun         JobRun?             @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  collectedAt    DateTime
  rawPayloadHash String
  storagePath    String?
  recordCount    Int                 @default(0)
  isDemo         Boolean             @default(false)
  createdAt      DateTime            @default(now())
  observations   SignalObservation[]
  evidence       Evidence[]

  @@index([workspaceId, collectedAt])
}

model Signal {
  id                 String              @id @default(cuid())
  workspaceId        String
  workspace          Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title              String
  summary            String
  type               SignalType
  market             Market
  audience           String
  status             SignalStatus        @default(WATCH)
  priority           SignalPriority      @default(WATCH)
  riskLevel          RiskLevel           @default(LOW)
  stage              TrendStage          @default(MONITOR)
  strength           Int                 @default(0)
  trendWindow        String?
  decision           String?
  nextAction         String?
  tags               Json?
  scoreDrivers       Json?
  dedupeKey          String?
  importBatchId      String?
  importBatch        ImportBatch?        @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  lastIngestedAt     DateTime?
  processedAt        DateTime?
  origin             DataOrigin
  sourceId           String
  source             Source              @relation(fields: [sourceId], references: [id])
  confidence         ConfidenceBand      @default(LOW)
  evidenceCount      Int                 @default(0)
  isDemo             Boolean             @default(false)
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  observations       SignalObservation[]
  scores             SignalScore[]
  evidence           Evidence[]
  compliance         ComplianceFlag[]
  decisionQueueItems DecisionQueueItem[]
  auditEvents        AuditEvent[]
  ingestRequests     IngestRequest[]

  @@unique([workspaceId, dedupeKey])
  @@index([market, type, status])
  @@index([priority, riskLevel, stage])
  @@index([origin, isDemo])
  @@index([workspaceId, market, type, status])
  @@index([workspaceId, priority, riskLevel, stage])
}

model SignalObservation {
  id           String          @id @default(cuid())
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId     String
  signal       Signal          @relation(fields: [signalId], references: [id], onDelete: Cascade)
  snapshotId   String?
  snapshot     SourceSnapshot? @relation(fields: [snapshotId], references: [id])
  observedAt   DateTime
  rank         Int?
  postCount    Int?
  viewCount    BigInt?
  likeCount    BigInt?
  commentCount BigInt?
  shareCount   BigInt?
  rawMetrics   Json?
  createdAt    DateTime        @default(now())

  @@index([signalId, observedAt])
  @@index([workspaceId, observedAt])
}

model SignalScore {
  id                    String         @id @default(cuid())
  workspaceId           String
  workspace             Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId              String
  signal                Signal         @relation(fields: [signalId], references: [id], onDelete: Cascade)
  calculatedAt          DateTime       @default(now())
  score                 Int
  confidence            ConfidenceBand
  velocity7d            Int
  acceleration          Int
  brazilFit             Int
  usTransferability     Int
  formatRepeatability   Int
  creatorSignal         Int
  audioCommercialUsable Int
  revivalStrength       Int
  evidenceQuality       Int
  riskPenalty           Int
  modelVersion          String         @default("score-v0.1")
  explanation           String?

  @@index([signalId, calculatedAt])
  @@index([workspaceId, calculatedAt])
}

model Evidence {
  id            String          @id @default(cuid())
  workspaceId   String
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId      String?
  signal        Signal?         @relation(fields: [signalId], references: [id], onDelete: SetNull)
  sourceId      String
  source        Source          @relation(fields: [sourceId], references: [id])
  importBatchId String?
  importBatch   ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId      String?
  jobRun        JobRun?         @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  snapshotId    String?
  snapshot      SourceSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  dedupeKey     String?
  title         String
  url           String?
  excerpt       String?
  note          String?
  quality       ConfidenceBand  @default(LOW)
  capturedAt    DateTime
  isDemo        Boolean         @default(false)
  createdAt     DateTime        @default(now())

  @@unique([workspaceId, dedupeKey])
  @@index([sourceId, capturedAt])
  @@index([signalId, capturedAt])
  @@index([workspaceId, capturedAt])
}

model DecisionQueueItem {
  id          String              @id @default(cuid())
  workspaceId String
  workspace   Workspace           @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId    String
  signal      Signal              @relation(fields: [signalId], references: [id], onDelete: Cascade)
  status      DecisionQueueStatus @default(ACTIVE)
  label       String?
  notes       String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  @@unique([workspaceId, signalId])
  @@index([status, createdAt])
  @@index([workspaceId, status, createdAt])
}

model AuditEvent {
  id            String         @id @default(cuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  type          AuditEventType
  signalId      String?
  signal        Signal?        @relation(fields: [signalId], references: [id], onDelete: SetNull)
  sourceId      String?
  source        Source?        @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  importBatchId String?
  importBatch   ImportBatch?   @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId      String?
  jobRun        JobRun?        @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  label         String
  value         String
  tone          String         @default("violet")
  message       String?
  actor         String         @default("system")
  metadata      Json?
  eventAt       DateTime       @default(now())
  createdAt     DateTime       @default(now())

  @@index([signalId, eventAt])
  @@index([type, eventAt])
  @@index([workspaceId, type, eventAt])
}

model ComplianceFlag {
  id          String             @id @default(cuid())
  workspaceId String
  workspace   Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  signalId    String?
  signal      Signal?            @relation(fields: [signalId], references: [id], onDelete: SetNull)
  severity    ComplianceSeverity
  code        String
  message     String
  policyRef   String?
  resolvedAt  DateTime?
  createdAt   DateTime           @default(now())

  @@index([severity, resolvedAt])
  @@index([workspaceId, severity, resolvedAt])
}

model MediaAsset {
  id             String            @id @default(cuid())
  workspaceId    String
  workspace      Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  ownerLabel     String
  origin         DataOrigin
  storagePath    String
  mimeType       String
  fileHash       String
  isLicensed     Boolean           @default(false)
  metadataReport Json?
  createdAt      DateTime          @default(now())
  derivatives    MediaDerivative[]

  @@index([workspaceId, origin, createdAt])
}

model MediaDerivative {
  id          String     @id @default(cuid())
  workspaceId String
  workspace   Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  mediaId     String
  media       MediaAsset @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  purpose     String
  storagePath String
  fileHash    String
  createdAt   DateTime   @default(now())

  @@index([workspaceId, createdAt])
}

model JobRun {
  id              String           @id @default(cuid())
  workspaceId     String
  workspace       Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  queue           String           @default("default")
  handler         String           @default("generic")
  name            String
  status          JobStatus        @default(QUEUED)
  stage           IngestStepName?
  requestId       String?
  request         IngestRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  importBatchId   String?
  importBatch     ImportBatch?     @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  dedupeKey       String?
  createdBy       String           @default("system")
  attemptCount    Int              @default(0)
  maxAttempts     Int              @default(5)
  availableAt     DateTime         @default(now())
  leaseExpiresAt  DateTime?
  claimToken      String?
  payload         Json?
  startedAt       DateTime?
  finishedAt      DateTime?
  error           String?
  lastError       String?
  deadLetteredAt  DateTime?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  snapshots       SourceSnapshot[]
  evidence        Evidence[]
  videos          Video[]
  trendSnapshots  TrendSnapshot[]
  trendEvidence   TrendEvidence[]
  auditEvents     AuditEvent[]

  @@unique([workspaceId, dedupeKey])
  @@index([name, status, createdAt])
  @@index([queue, status, availableAt])
  @@index([importBatchId, status])
  @@index([workspaceId, status, availableAt])
}

model IngestRequest {
  id            String            @id @default(cuid())
  workspaceId   String
  workspace     Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  requestKey    String
  type          IngestRequestType
  status        IngestStatus      @default(QUEUED)
  market        Market
  origin        DataOrigin
  connectorId   String?
  connector     Connector?        @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  sourceId      String?
  source        Source?           @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  signalId      String?
  signal        Signal?           @relation(fields: [signalId], references: [id], onDelete: SetNull)
  title         String
  submittedBy   String            @default("operator")
  submittedAt   DateTime          @default(now())
  collectedAt   DateTime?
  processedAt   DateTime?
  completedAt   DateTime?
  error         String?
  payload       Json?
  isDemo        Boolean           @default(false)
  importBatches ImportBatch[]
  jobRuns       JobRun[]

  @@unique([workspaceId, requestKey])
  @@index([status, submittedAt])
  @@index([market, origin, type])
  @@index([workspaceId, status, submittedAt])
}

model ImportBatch {
  id             String           @id @default(cuid())
  workspaceId    String
  workspace      Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  idempotencyKey String
  kind           ImportBatchKind
  status         IngestStatus     @default(QUEUED)
  market         Market
  origin         DataOrigin
  connectorId    String?
  connector      Connector?       @relation(fields: [connectorId], references: [id], onDelete: SetNull)
  requestId      String?
  request        IngestRequest?   @relation(fields: [requestId], references: [id], onDelete: SetNull)
  sourceId       String?
  source         Source?          @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title          String
  itemCount      Int              @default(0)
  payloadHash    String?
  payload        Json?
  collectedAt    DateTime?
  processedAt    DateTime?
  completedAt    DateTime?
  error          String?
  isDemo         Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  steps          IngestionStep[]
  jobRuns        JobRun[]
  snapshots      SourceSnapshot[]
  signals        Signal[]
  evidence       Evidence[]
  videos         Video[]
  trendSnapshots TrendSnapshot[]
  trendEvidence  TrendEvidence[]
  auditEvents    AuditEvent[]

  @@unique([workspaceId, idempotencyKey])
  @@index([status, createdAt])
  @@index([market, origin, kind])
  @@index([workspaceId, status, createdAt])
}

model IngestionStep {
  id          String         @id @default(cuid())
  workspaceId String
  workspace   Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  batchId     String
  batch       ImportBatch    @relation(fields: [batchId], references: [id], onDelete: Cascade)
  name        IngestStepName
  status      IngestStatus   @default(QUEUED)
  sequence    Int
  startedAt   DateTime?
  completedAt DateTime?
  error       String?
  notes       String?
  createdAt   DateTime       @default(now())

  @@index([batchId, sequence])
  @@index([name, status])
  @@index([workspaceId, name, status])
}

model Creator {
  id            String          @id @default(cuid())
  workspaceId   String
  workspace     Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId      String?
  source        Source?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  handle        String
  displayName   String?
  profileUrl    String?
  market        Market
  origin        DataOrigin
  followerCount BigInt?
  averageViews  BigInt?
  currentScore  Int             @default(0)
  dedupeKey     String
  firstSeenAt   DateTime        @default(now())
  lastSeenAt    DateTime        @default(now())
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  videos        Video[]
  snapshots     TrendSnapshot[]
  evidence      TrendEvidence[]

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId, market, currentScore])
  @@index([workspaceId, handle])
}

model Sound {
  id                     String          @id @default(cuid())
  workspaceId            String
  workspace              Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId               String?
  source                 Source?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  title                  String
  authorName             String?
  soundUrl               String?
  market                 Market
  origin                 DataOrigin
  isCommerciallyUsable   Boolean?
  commercialRightsStatus String?
  videoCount             Int?
  currentScore           Int             @default(0)
  dedupeKey              String
  firstSeenAt            DateTime        @default(now())
  lastSeenAt             DateTime        @default(now())
  createdAt              DateTime        @default(now())
  updatedAt              DateTime        @updatedAt
  videos                 Video[]
  snapshots              TrendSnapshot[]
  evidence               TrendEvidence[]

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId, market, currentScore])
  @@index([workspaceId, title])
}

model Hashtag {
  id           String          @id @default(cuid())
  workspaceId  String
  workspace    Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId     String?
  source       Source?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  tag          String
  displayTag   String
  market       Market
  origin       DataOrigin
  postCount    BigInt?
  viewCount    BigInt?
  currentScore Int             @default(0)
  dedupeKey    String
  firstSeenAt  DateTime        @default(now())
  lastSeenAt   DateTime        @default(now())
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  videos       VideoHashtag[]
  snapshots    TrendSnapshot[]
  evidence     TrendEvidence[]

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId, market, currentScore])
  @@index([workspaceId, tag])
}

model Video {
  id                  String          @id @default(cuid())
  workspaceId         String
  workspace           Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId            String
  source              Source          @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  creatorId           String?
  creator             Creator?        @relation(fields: [creatorId], references: [id], onDelete: SetNull)
  soundId             String?
  sound               Sound?          @relation(fields: [soundId], references: [id], onDelete: SetNull)
  importBatchId       String?
  importBatch         ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId            String?
  jobRun              JobRun?         @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  platformVideoId     String?
  url                 String?
  title               String
  caption             String?
  market              Market
  origin              DataOrigin
  postedAt            DateTime?
  collectedAt         DateTime
  firstSeenAt         DateTime        @default(now())
  lastSeenAt          DateTime        @default(now())
  currentViewCount    BigInt          @default(0)
  currentLikeCount    BigInt          @default(0)
  currentCommentCount BigInt          @default(0)
  currentShareCount   BigInt          @default(0)
  currentSaveCount    BigInt          @default(0)
  growthViews         BigInt          @default(0)
  velocityScore       Int             @default(0)
  accelerationScore   Int             @default(0)
  recencyScore        Int             @default(0)
  consistencyScore    Int             @default(0)
  trendScore          Int             @default(0)
  scoreVersion        String          @default("video-score-v0.1")
  confidence          ConfidenceBand  @default(LOW)
  dedupeKey           String
  isDemo              Boolean         @default(false)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  hashtags            VideoHashtag[]
  snapshots           TrendSnapshot[]
  evidence            TrendEvidence[]

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId, market, trendScore])
  @@index([workspaceId, collectedAt])
  @@index([workspaceId, sourceId])
  @@index([workspaceId, creatorId])
  @@index([workspaceId, soundId])
}

model VideoHashtag {
  videoId   String
  video     Video    @relation(fields: [videoId], references: [id], onDelete: Cascade)
  hashtagId String
  hashtag   Hashtag  @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([videoId, hashtagId])
  @@index([hashtagId])
}

model TrendSnapshot {
  id                String          @id @default(cuid())
  workspaceId       String
  workspace         Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  entityType        TrendEntityType
  videoId           String?
  video             Video?          @relation(fields: [videoId], references: [id], onDelete: Cascade)
  creatorId         String?
  creator           Creator?        @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  soundId           String?
  sound             Sound?          @relation(fields: [soundId], references: [id], onDelete: Cascade)
  hashtagId         String?
  hashtag           Hashtag?        @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  sourceId          String?
  source            Source?         @relation(fields: [sourceId], references: [id], onDelete: SetNull)
  importBatchId     String?
  importBatch       ImportBatch?    @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId          String?
  jobRun            JobRun?         @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  observedAt        DateTime
  viewCount         BigInt?
  likeCount         BigInt?
  commentCount      BigInt?
  shareCount        BigInt?
  saveCount         BigInt?
  followerCount     BigInt?
  videoCount        Int?
  postCount         BigInt?
  rawMetrics        Json?
  growthViews       BigInt          @default(0)
  velocityScore     Int             @default(0)
  accelerationScore Int             @default(0)
  recencyScore      Int             @default(0)
  consistencyScore  Int             @default(0)
  trendScore        Int             @default(0)
  scoreVersion      String          @default("video-score-v0.1")
  createdAt         DateTime        @default(now())
  evidence          TrendEvidence[]

  @@index([workspaceId, entityType, observedAt])
  @@index([workspaceId, videoId, observedAt])
  @@index([workspaceId, trendScore])
}

model TrendEvidence {
  id            String         @id @default(cuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  sourceId      String
  source        Source         @relation(fields: [sourceId], references: [id], onDelete: Restrict)
  importBatchId String?
  importBatch   ImportBatch?   @relation(fields: [importBatchId], references: [id], onDelete: SetNull)
  jobRunId      String?
  jobRun        JobRun?        @relation(fields: [jobRunId], references: [id], onDelete: SetNull)
  snapshotId    String?
  snapshot      TrendSnapshot? @relation(fields: [snapshotId], references: [id], onDelete: SetNull)
  videoId       String?
  video         Video?         @relation(fields: [videoId], references: [id], onDelete: Cascade)
  creatorId     String?
  creator       Creator?       @relation(fields: [creatorId], references: [id], onDelete: Cascade)
  soundId       String?
  sound         Sound?         @relation(fields: [soundId], references: [id], onDelete: Cascade)
  hashtagId     String?
  hashtag       Hashtag?       @relation(fields: [hashtagId], references: [id], onDelete: Cascade)
  title         String
  url           String?
  excerpt       String?
  note          String?
  origin        DataOrigin
  confidence    ConfidenceBand @default(LOW)
  capturedAt    DateTime
  dedupeKey     String?
  isDemo        Boolean        @default(false)
  createdAt     DateTime       @default(now())

  @@unique([workspaceId, dedupeKey])
  @@index([workspaceId, capturedAt])
  @@index([workspaceId, videoId, capturedAt])
  @@index([workspaceId, sourceId, capturedAt])
}

model SearchQueryLog {
  id          String           @id @default(cuid())
  workspaceId String
  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  query       String
  market      Market?
  entityType  TrendEntityType?
  sort        String
  filters     Json?
  resultCount Int              @default(0)
  createdAt   DateTime         @default(now())

  @@index([workspaceId, createdAt])
  @@index([workspaceId, query])
}

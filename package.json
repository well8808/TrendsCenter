{
  "name": "instagram-reels-command-center",
  "version": "0.1.0",
  "private": true,
  "description": "Premium Instagram Reels market intelligence command center focused on Brazil with US early-signal monitoring.",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "eslint .",
    "test": "vitest run",
    "test:integration": "vitest run src/test/http/backend-api.integration.test.ts src/test/operations/backend-ops.integration.test.ts",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "node prisma/seed.mjs",
    "db:status": "prisma migrate status",
    "smoke:http": "node scripts/smoke-http-backend.mjs"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@neondatabase/serverless": "^1.1.0",
    "@prisma/adapter-neon": "^7.7.0",
    "@prisma/client": "latest",
    "@tanstack/react-query": "latest",
    "clsx": "latest",
    "gsap": "^3.15.0",
    "lucide-react": "latest",
    "motion": "latest",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest",
    "tailwind-merge": "latest",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "^0.184.0",
    "dotenv": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "postcss": "latest",
    "prisma": "latest",
    "tailwindcss": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}

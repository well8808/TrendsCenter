DATABASE_URL="postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
DATABASE_URL_UNPOOLED="postgres://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require"
NEXT_PUBLIC_APP_ENV="production"
NEXT_PUBLIC_APP_URL="https://instagram-reels-command-center.vercel.app"
DATABASE_RUNTIME="postgres-neon"
AUTH_SESSION_COOKIE="tmcc_session"
AUTH_EMAIL_DELIVERY_MODE="outbox"
CRON_SECRET="replace-with-a-random-string"
INTERNAL_API_TOKEN="replace-with-a-random-string"

# Email real via Resend e opcional/futuro para o MVP atual.
# Deixe ausente ate existir dominio/remetente verificado e envio real validado.
# RESEND_API_KEY="re_xxxxxxxxx"
# AUTH_EMAIL_FROM="Instagram Market Intel <alerts@yourdomain.com>"

# Instagram OAuth / Meta Graph API.
# Opcional para build/seed, obrigatorio para conectar conta profissional real em /sources.
# Nunca exponha INSTAGRAM_CLIENT_SECRET no front-end.
# INSTAGRAM_CLIENT_ID="" # App ID / Client ID do produto Instagram no Meta for Developers
# INSTAGRAM_CLIENT_SECRET=""
# INSTAGRAM_REDIRECT_URI="https://instagram-reels-command-center.vercel.app/api/connectors/instagram/callback"
# INSTAGRAM_SCOPES="instagram_business_basic,instagram_business_manage_insights"
# OAUTH_TOKEN_ENCRYPTION_KEY="32+ chars randomicos para criptografar tokens OAuth no servidor"

# Vercel Marketplace/Neon tambem pode injetar:
# POSTGRES_URL=
# POSTGRES_URL_NON_POOLING=
